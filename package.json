{
  "name": "onpay_solana",
  "version": "0.1.0",
  "private": true,
  "description": "OnPay — non-custodial any-to-stable payment gateway on Solana",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run format:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@solana/pay": "0.2.5",
    "@solana/spl-token": "0.4.9",
    "@solana/wallet-adapter-base": "0.9.24",
    "@solana/wallet-adapter-react": "0.15.36",
    "@solana/web3.js": "1.98.0",
    "bs58": "6.0.0",
    "drizzle-orm": "0.45.2",
    "jose": "5.9.6",
    "next": "15.5.15",
    "pino": "9.6.0",
    "postgres": "3.4.5",
    "qrcode.react": "4.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "0.0.1",
    "tweetnacl": "1.0.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "9.39.4",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",
    "autoprefixer": "10.4.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.0.1",
    "globals": "15.14.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "pino-pretty": "13.0.0",
    "postcss": "8.5.1",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.10",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "typescript-eslint": "8.21.0",
    "vitest": "3.2.4"
  },
  "overrides": {
    "esbuild": "0.25.12",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3"
  }
}
