# ============================================================================
# OnPay — Environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values. The app validates every
# variable at startup via src/config/env.ts and will fail fast if any are
# missing or malformed. This is by design — never run the app with partial
# configuration.
#
# SECURITY NOTES:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
#   Never put secrets in them.
# - Everything else is server-only.
# - Never commit .env.local or any file containing real values.
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
# "development" | "production" | "test"
NODE_ENV=development

# "devnet" | "mainnet-beta"
# Controls which Solana cluster the app targets.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Public-facing URL of the app (used for absolute links, icon URLs, CSP origin).
# In development this is typically http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Solana RPC
# ----------------------------------------------------------------------------
# Primary RPC endpoint. Use Helius or Triton for production.
# Devnet default: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional fallback RPC endpoint used if the primary fails.
SOLANA_RPC_FALLBACK_URL=

# ----------------------------------------------------------------------------
# Jupiter (swap aggregator)
# ----------------------------------------------------------------------------
# Jupiter v6 API base URL. Leave as default for public endpoint.
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Maximum allowed slippage in basis points (100 bps = 1%).
# Hard cap — the app rejects any request with higher slippage.
JUPITER_MAX_SLIPPAGE_BPS=100

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Supabase project URL and keys.
# Anon key is safe to expose; service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Merchant settlement
# ----------------------------------------------------------------------------
# Default settlement token mint (USDC on devnet or mainnet-beta).
# Devnet USDC: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
DEFAULT_SETTLEMENT_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# "fatal" | "error" | "warn" | "info" | "debug" | "trace"
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Invoice lifecycle
# ----------------------------------------------------------------------------
# How long an unpaid invoice remains valid before expiring (in seconds).
INVOICE_TTL_SECONDS=600
